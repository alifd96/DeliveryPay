rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: customers
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required)
    //   - uid: string (required, must match auth.uid)
    //   - createdAt: timestamp (required)
    //
    // Collection: orders
    // Document ID: auto-generated
    // Fields:
    //   - customerId: string (required)
    //   - customerName: string (required)
    //   - items: list (required, objects with shop and price)
    //   - total: number (required)
    //   - uid: string (required, must match auth.uid)
    //   - createdAt: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "ahmadfakherdine274@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidCustomer(data) {
      return data.keys().hasAll(['name', 'uid', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             (!('phone' in data) || data.phone is string) &&
             (!('address' in data) || data.address is string) &&
             data.uid == request.auth.uid &&
             data.createdAt is timestamp;
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['customerId', 'customerName', 'items', 'total', 'uid', 'createdAt']) &&
             data.customerId is string &&
             data.customerName is string &&
             data.items is list &&
             data.total is number &&
             (!('deliveryFee' in data) || data.deliveryFee is number) &&
             (!('status' in data) || data.status in ['pending', 'delivered', 'paid']) &&
             data.uid == request.auth.uid &&
             data.createdAt is timestamp;
    }

    match /customers/{customerId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && isValidCustomer(request.resource.data);
      allow update: if (isDocOwner() || isAdmin()) && isValidCustomer(request.resource.data);
      allow delete: if isDocOwner() || isAdmin();
    }

    match /orders/{orderId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && isValidOrder(request.resource.data);
      allow update: if (isDocOwner() || isAdmin()) && isValidOrder(request.resource.data);
      allow delete: if isDocOwner() || isAdmin();
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isOwner(userId) && (!('role' in request.resource.data) || request.resource.data.role == 'user');
      allow update: if isOwner(userId) && (!('role' in request.resource.data) || request.resource.data.role == resource.data.role) || isAdmin();
    }
  }
}
